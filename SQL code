# What is our average revenue per visit, and which department has the highest 'average revenue' per visit?
;
SELECT 
    p1.department,
    LEFT(AVG(b1.total_amount), 7) AS 'average revenue per visit'
FROM
    billing AS b1
        JOIN
    encounters AS e1 ON b1.encounter_id = e1.encounter_id
        JOIN
    physicians AS p1 ON p1.doc_id = e1.doc_id
WHERE
    total_amount > 0 AND status != 'Error'
GROUP BY p1.department
ORDER BY 'average revenue per visit'
;
