# How many visits did the patient make to the hospital within 30 days or less of the date of his previous visit?
SELECT encounter_date , str_to_date(encounter_date,'%Y-%m-%d')
from encounters
;
update encounters
set `encounter_date` = str_to_date(encounter_date,'%Y-%m-%d')
;
with cte_visit as (
select patient_id ,encounter_date as visit_1 ,LAG(encounter_date) OVER(PARTITION BY patient_id ORDER BY encounter_date) AS visit_2
,datediff(encounter_date,LAG(encounter_date) OVER(PARTITION BY patient_id ORDER BY encounter_date)) as within_30_days
from encounters
where patient_id  not in ("P0134","P0615","P0105","P0079","P0473")  
	)
    select *
    from cte_visit
    where `within_30_days` = 30 or (`within_30_days` < 30)
    
;
